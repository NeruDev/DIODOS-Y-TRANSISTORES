{
  "name": "Diodos y Transistores - Entorno Academico",
  "image": "mcr.microsoft.com/devcontainers/python:3.12-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/desktop-gui:1": {
      "version": "latest",
      "display": ":1"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y python3-tk && pip install -r requirements.txt",
  "remoteEnv": {
    "DISPLAY": ":1"
  }
}
